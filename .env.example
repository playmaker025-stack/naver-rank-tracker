# 네이버 쇼핑 Search API
NAVER_CLIENT_ID=your_naver_client_id
NAVER_CLIENT_SECRET=your_naver_client_secret

# 카카오 REST API
KAKAO_REST_API_KEY=your_kakao_rest_api_key

# 카카오 액세스/리프레시 토큰 (get_kakao_token.py 스크립트로 발급)
KAKAO_ACCESS_TOKEN_ME=your_access_token_for_me
KAKAO_REFRESH_TOKEN_ME=your_refresh_token_for_me

# 추가 수신자 (동일 앱에서 추가 수신자가 직접 get_kakao_token.py 실행)
KAKAO_ACCESS_TOKEN_EXTRA=your_access_token_for_extra
KAKAO_REFRESH_TOKEN_EXTRA=your_refresh_token_for_extra

# 배포 URL (Railway 배포 후 카카오 알림 링크용)
# 예: https://naver-rank-tracker-xxx.railway.app
APP_URL=https://your-railway-url.railway.app

# Railway가 자동으로 주입 (직접 설정 불필요)
# DATABASE_URL=postgresql://...
